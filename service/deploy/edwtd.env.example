# edwtd runtime environment — copy to /etc/edwtd/edwtd.env (chmod 600) and fill in.
# Never commit the real file; this is just a template.

# Upstream feed (default is fine).
EDWT_SOURCE_URL=https://www.edwaittimes.ca/api/wait-times

# Poll cadence in milliseconds.
POLL_INTERVAL_MS=60000

# Supabase Postgres — the direct connection (port 5432). Second-writer path.
# DB name on Supabase is `postgres`, not `edwt`.
DATABASE_URL=postgres://postgres:PASSWORD@db.YOUR_REF.supabase.co:5432/postgres?sslmode=require
EDWT_WRITE_DB=true

# Cloudflare R2 (S3-compatible) — raw archive target.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=edwt-raw

# Metrics / health server.
EDWT_HTTP_ADDR=:8080
EDWT_READY_MAX_STALENESS=3m
