# Postgres connection (matches docker-compose.yml; host port 5433)
DATABASE_URL=postgres://edwt:edwt@localhost:5433/edwt

# Upstream wait-times feed
EDWT_SOURCE_URL=https://www.edwaittimes.ca/api/wait-times

# Poll cadence for the long-running worker (ms). The source refreshes reports
# about every minute, so 60000 captures essentially every report.
POLL_INTERVAL_MS=60000
